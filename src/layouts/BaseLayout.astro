---
import "../styles/global.css";
import { profile } from "../data/profile";

type Props = {
  title?: string;
  description?: string;
  active?: "home" | "publications" | "cv";
};

const {
  title = `${profile.name} | ${profile.title}`,
  description = profile.shortSummary,
  active = "home"
} = Astro.props;

const navItems = [
  { key: "home", label: "Home", href: "/" },
  { key: "publications", label: "Publications", href: "/publications/" },
  { key: "cv", label: "CV", href: "/cv/" }
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="theme-color" content="#17201b" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <nav class="site-nav" aria-label="Primary navigation">
        {
          navItems.map((item) => (
            <a href={item.href} aria-current={active === item.key ? "page" : undefined}>
              {item.label}
            </a>
          ))
        }
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div>
        <strong>{profile.name}</strong>
        <span>{profile.title}, {profile.affiliation}</span>
      </div>
      <div class="footer-links">
        <a href={`mailto:${profile.email}`}>Email</a>
        {
          profile.links.slice(0, 3).map((link) => (
            <a href={link.href} target="_blank" rel="noreferrer">{link.label}</a>
          ))
        }
      </div>
    </footer>
  </body>
</html>
