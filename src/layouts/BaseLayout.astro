---
import "../styles/global.css";
import { profile } from "../data/profile";

type Props = {
  title?: string;
  description?: string;
  active?: "home" | "publications" | "cv";
};

const {
  title = `${profile.name} | ${profile.title}`,
  description = profile.shortSummary,
  active = "home"
} = Astro.props;

const withBase = (path: string) => {
  const base = import.meta.env.BASE_URL.endsWith("/")
    ? import.meta.env.BASE_URL
    : `${import.meta.env.BASE_URL}/`;
  return `${base}${path.replace(/^\//, "")}`;
};

const navItems = [
  { key: "home", label: "Home", href: withBase("/") },
  { key: "publications", label: "Publications", href: withBase("/publications/") },
  { key: "cv", label: "CV", href: withBase("/cv/") }
];

const canonicalUrl = Astro.url?.href;
const ogImageUrl = new URL(withBase("/favicon.svg"), Astro.site ?? Astro.url).href;
const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: profile.name,
  jobTitle: profile.title,
  affiliation: profile.affiliation,
  email: `mailto:${profile.email}`,
  url: canonicalUrl,
  sameAs: profile.links.map((link) => link.href)
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="theme-color" content="#17201b" />
    <link rel="icon" href={withBase("/favicon.svg")} type="image/svg+xml" />
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <nav class="site-nav" aria-label="Primary navigation">
        {
          navItems.map((item) => (
            <a href={item.href} aria-current={active === item.key ? "page" : undefined}>
              {item.label}
            </a>
          ))
        }
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div>
        <strong>{profile.name}</strong>
        <span>{profile.title}, {profile.affiliation}</span>
      </div>
      <div class="footer-links">
        <a href={`mailto:${profile.email}`}>Email</a>
        {
          profile.links.slice(0, 3).map((link) => (
            <a href={link.href} target="_blank" rel="noreferrer">{link.label}</a>
          ))
        }
      </div>
    </footer>
  </body>
</html>
