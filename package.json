{
  "name": "tomas-martinovic-website",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "cv:pdf": "npm run build && node scripts/generate-cv-pdf.mjs",
    "cv:pdf:from-dist": "node scripts/generate-cv-pdf.mjs",
    "cv:docx": "pandoc src/content/cv.md --from markdown+yaml_metadata_block --to docx --standalone --output public/CV_Tomas_Martinovic_English_Full.docx"
  },
  "dependencies": {
    "astro": "^7.0.4"
  },
  "devDependencies": {
    "@astrojs/markdown-remark": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.1.0",
    "@fortawesome/free-solid-svg-icons": "^7.1.0",
    "playwright": "^1.61.1",
    "remark-directive": "^4.0.0",
    "simple-icons": "^16.0.0"
  }
}
